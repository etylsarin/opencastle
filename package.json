{
  "name": "opencastle",
  "version": "0.31.5",
  "type": "module",
  "description": "Multi-agent orchestration framework for AI coding assistants",
  "bin": {
    "opencastle": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agents",
    "copilot",
    "cursor",
    "claude",
    "orchestration",
    "multi-agent",
    "coding-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etylsarin/opencastle.git"
  },
  "bugs": {
    "url": "https://github.com/etylsarin/opencastle/issues"
  },
  "homepage": "https://www.opencastle.dev/",
  "license": "MIT",
  "author": "Filip Mares",
  "scripts": {
    "build": "npm run cli:build && npm run dashboard:build",
    "cli:build": "tsc",
    "test": "vitest run",
    "dashboard:generate-demo-db": "tsx src/dashboard/scripts/generate-demo-db.ts --out .opencastle/convoy-demo.db --events-out .opencastle/convoy-demo.events.ndjson",
    "dashboard:etl": "tsx src/dashboard/scripts/etl.ts --db .opencastle/convoy-demo.db --out src/dashboard/public/data --events .opencastle/convoy-demo.events.ndjson",
    "dashboard:test": "tsx src/dashboard/scripts/integration-test.ts",
    "dashboard:dev": "astro dev --root src/dashboard --port 4300",
    "dashboard:build": "astro build --root src/dashboard",
    "dashboard:preview": "astro preview --root src/dashboard --port 4300",
    "website:dev": "astro dev --root website",
    "website:build": "astro build --root website",
    "website:preview": "astro preview --root website",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "astro": "^5.5.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.30",
    "valibot": "^1.2.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "@anthropic-ai/agent-sdk": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/agent-sdk": {
      "optional": true
    }
  }
}
