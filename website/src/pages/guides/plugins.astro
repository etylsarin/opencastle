---
import '../../styles/global.css';

const title = 'Plugin Setup Guide — OpenCastle';
const description = 'Configure MCP servers and tools for your AI coding agents. Each plugin provides an MCP integration, optional agent skills, and tool access.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icon-192.png" />
  </head>
  <body>
    <main class="guide">
      <a href="/" class="back-link">← Back to OpenCastle</a>

      <h1>Plugin Setup Guide</h1>
      <p class="subtitle">
        Configure MCP servers and tools for your AI coding agents. Each plugin
        provides an MCP integration, optional agent skills, and tool access.
      </p>

      <nav class="toc">
        <h2>Contents</h2>
        <ol>
          <li><a href="#cms-plugins">CMS Plugins</a> — Sanity, Contentful, Strapi</li>
          <li><a href="#database-plugins">Database Plugins</a> — Supabase, Convex</li>
          <li><a href="#deployment">Deployment</a> — Vercel</li>
          <li><a href="#monorepo">Monorepo</a> — NX</li>
          <li><a href="#issue-trackers">Issue Trackers</a> — Linear, Jira</li>
          <li><a href="#notifications">Notifications</a> — Slack, Microsoft Teams</li>
        </ol>
      </nav>

      <hr />

      <!-- ============================================================ -->
      <!-- CMS Plugins                                                   -->
      <!-- ============================================================ -->

      <section id="cms-plugins">
        <h2>CMS Plugins</h2>

        <!-- Sanity -->
        <section id="sanity">
          <h3>Sanity</h3>
          <p>GROQ queries, real-time collaboration.</p>
          <table>
            <thead>
              <tr>
                <th>Auth Type</th>
                <th>MCP Package</th>
                <th>Official Docs</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code class="badge-oauth">OAuth</code></td>
                <td>HTTP/OAuth</td>
                <td><a href="https://www.sanity.io/docs" target="_blank" rel="noopener">sanity.io/docs</a></td>
              </tr>
            </tbody>
          </table>
          <div class="callout">
            <strong>OAuth:</strong> This plugin uses OAuth. The MCP server will open
            a browser window for authentication when you first connect.
          </div>
          <h4>MCP Config</h4>
          <pre><code>{`{
  "servers": {
    "Sanity": {
      "type": "http",
      "url": "https://mcp.sanity.io"
    }
  }
}`}</code></pre>
        </section>

        <!-- Contentful -->
        <section id="contentful">
          <h3>Contentful</h3>
          <p>GraphQL / REST API, structured content.</p>
          <table>
            <thead>
              <tr>
                <th>Auth Type</th>
                <th>MCP Package</th>
                <th>Official Docs</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="badge-noauth">No auth</span></td>
                <td><code>@contentful/mcp-server</code></td>
                <td><a href="https://www.contentful.com/developers/docs/" target="_blank" rel="noopener">contentful.com/developers/docs</a></td>
              </tr>
            </tbody>
          </table>
          <h4>MCP Config</h4>
          <pre><code>{`{
  "servers": {
    "Contentful": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@contentful/mcp-server"]
    }
  }
}`}</code></pre>
        </section>

