        margin: 0 2px;
        font-weight: 400;
      }
      .docs-header__icon { border-radius: 6px; }
      .docs-header__title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: -.01em;
      }

      /* ── Layout ── */
      .docs-layout {
        display: flex;
        max-width: var(--max-width);
        margin: 0 auto;
        position: relative;
      }

      /* ── Sidebar ── */
      .docs-sidebar {
        position: sticky;
        top: 56px;
        height: calc(100vh - 56px);
        width: 200px;
        flex-shrink: 0;
        padding: 24px 0 24px 24px;
        overflow-y: auto;
        display: none;
      }
      @media (min-width: 1024px) {
        .docs-sidebar { display: block; }
      }
      .docs-sidebar__list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .docs-sidebar__link {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        padding: 8px 14px;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-tertiary);
        text-decoration: none;
        border-radius: 8px;
        transition: color var(--transition-fast), background var(--transition-fast);
        line-height: 1.4;
      }
      .docs-sidebar__link:hover {
        color: var(--text-secondary);
        background: rgba(255, 255, 255, 0.04);
      }
      .docs-sidebar__link--active {
        color: var(--text-accent);
        background: rgba(167, 139, 250, 0.08);
        font-weight: 600;
      }
      .docs-sidebar__link svg {
        flex-shrink: 0;
        opacity: 0.7;
      }
      .docs-sidebar__link--active svg {
        opacity: 1;
      }

      /* ── Main ── */
      .docs-main {
        flex: 1;
        min-width: 0;
        max-width: 860px;
        padding: 32px 24px 64px;
      }

      /* ── Hero ── */
      .docs-hero {
        margin-bottom: 2.5rem;
      }
      .docs-hero__heading {
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -.02em;
        margin-bottom: .5rem;
      }
      .docs-hero__sub {
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.6;
      }

      /* ── Content sections ── */
      .content-section {
        margin-bottom: 3rem;
        scroll-margin-top: 72px;
      }
      .section-heading {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -.01em;
        margin-bottom: .75rem;
        padding-bottom: .5rem;
        border-bottom: 1px solid var(--border-color);
      }
      .section-text {
        color: var(--text-secondary);
        font-size: .95rem;
        line-height: 1.7;
        margin-bottom: 1rem;
      }
      .section-text em {
        color: var(--text-primary);
        font-style: italic;
      }
      .section-text strong {
        color: var(--text-primary);
      }

      /* ── Key insight box ── */
      .key-insight {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.25rem;
        background: var(--accent-glow);
        border: 1px solid rgba(167, 139, 250, .2);
        border-radius: 10px;
        margin-top: 1rem;
        margin-bottom: 1rem;
      }
      .key-insight__icon {
        flex-shrink: 0;
        color: var(--text-accent);
        margin-top: 2px;
      }
      .key-insight p {
        color: var(--text-secondary);
        font-size: .9rem;
        line-height: 1.6;
      }
      .key-insight strong {
        color: var(--text-accent);
      }

      /* ── Highlight box ── */
      .highlight-box {
        padding: 1.5rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-primary);
        border-radius: 12px;
        margin-bottom: 1.5rem;
      }
      .highlight-box__title {
        font-size: .8rem;
        font-weight: 600;
        color: var(--text-accent);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 1rem;
      }
      .highlight-box__list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: .5rem;
      }
      .highlight-box__list li {
        color: var(--text-secondary);
        font-size: .9rem;
        line-height: 1.6;
        padding-left: 1.25rem;
        position: relative;
      }
      .highlight-box__list li::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--text-accent);
      }
      .highlight-box__list li strong {
        color: var(--text-primary);
      }
      .highlight-box__list li code {
        font-size: .8rem;
        background: var(--bg-tertiary);
        padding: .1rem .35rem;
        border-radius: 4px;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        color: #c9d1d9;
      }

      /* ── DO/DON'T grid ── */
      .do-dont-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
      }
      @media (max-width: 700px) {
        .do-dont-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ── Cards ── */
      .card {
        border-radius: 10px;
        padding: 1.25rem;
        border: 1px solid;
      }
      .card--do {
        background: var(--color-do-bg);
        border-color: var(--color-do-border);
      }
      .card--dont {
        background: var(--color-dont-bg);
        border-color: var(--color-dont-border);
      }
      .card__header {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .75rem;
      }
      .card__icon {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
        font-weight: 700;
        flex-shrink: 0;
      }
      .card__icon--do {
        background: rgba(52, 211, 153, 0.15);
        color: var(--color-do-accent);
      }
      .card__icon--dont {
        background: rgba(248, 113, 113, 0.15);
        color: var(--color-dont-accent);
      }
      .card__label {
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
      }
      .card__label--do { color: var(--color-do-accent); }
      .card__label--dont { color: var(--color-dont-accent); }

      .card__body {}
      .card__title {
        font-size: .875rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: .5rem;
      }
      .card__example {
        display: block;
        font-size: .8rem;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        background: rgba(0, 0, 0, 0.25);
        padding: .75rem;
        border-radius: 6px;
        line-height: 1.5;
        color: var(--text-secondary);
        word-break: break-word;
        white-space: pre-wrap;
      }
      .card--do .card__example {
        border: 1px solid rgba(52, 211, 153, 0.1);
      }
      .card--dont .card__example {
        border: 1px solid rgba(248, 113, 113, 0.1);
      }
      .card__note {
        margin-top: .5rem;
        font-size: .8rem;
        color: var(--text-tertiary);
        line-height: 1.5;
        font-style: italic;
      }
      .card__aside {
        color: var(--text-tertiary);
        font-style: italic;
      }

      a { color: var(--text-accent); }

      /* ── Sidebar divider ── */
      .docs-sidebar__divider {
        height: 1px;
        background: var(--border-primary);
        margin: 12px 14px;
      }
      .docs-sidebar__label {
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-tertiary);
        padding: 8px 14px 4px;
      }

      /* ── Section divider ── */
      .section-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 3rem 0 2rem;
      }
      .section-divider__line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border-secondary), transparent);
      }
      .section-divider__label {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-accent);
        white-space: nowrap;
      }

      /* ── Docs section (for multi-agent) ── */
      .docs-section {
        margin-bottom: 3rem;
        scroll-margin-top: 72px;
      }
      .docs-section p {
        color: var(--text-secondary);
        font-size: .95rem;
        line-height: 1.7;
        margin-bottom: 1rem;
      }
      .docs-section p strong {
        color: var(--text-primary);
      }
      .section-title {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -.01em;
        margin-bottom: .75rem;
        padding-bottom: .5rem;
        border-bottom: 1px solid var(--border-color);
      }
      .docs-list {
        list-style: none;
        padding: 0;
        margin-bottom: 1.5rem;
      }
      .docs-list li {
        color: var(--text-secondary);
        font-size: .9rem;
        line-height: 1.6;
        padding-left: 1.25rem;
        position: relative;
        margin-bottom: .5rem;
      }
      .docs-list li::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--text-accent);
      }
      .docs-list li strong {
        color: var(--text-primary);
      }
      .docs-link { color: var(--text-accent); text-decoration: none; }
      .docs-link:hover { text-decoration: underline; }

      /* ── Architecture card ── */
      .architecture-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-primary);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.5rem;
      }
      .architecture-card__header {
        padding: .75rem 1.25rem;
        font-size: .8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-accent);
        border-bottom: 1px solid var(--border-primary);
        background: rgba(167, 139, 250, 0.04);
      }
      .architecture-card__flow {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .75rem;
        padding: 1.5rem;
      }
      .architecture-card__node {
        padding: .5rem 1.25rem;
        border-radius: 8px;
        font-size: .85rem;
        font-weight: 600;
        background: var(--bg-tertiary);
        border: 1px solid var(--border-secondary);
        color: var(--text-primary);
      }
      .architecture-card__node--lead {
        background: rgba(167, 139, 250, 0.1);
        border-color: rgba(167, 139, 250, 0.3);
        color: var(--text-accent);
      }
      .architecture-card__arrow {
        font-size: .75rem;
        color: var(--text-tertiary);
        font-style: italic;
      }
      .architecture-card__row {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      /* ── Agent tiers ── */
      .agent-tiers {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      @media (max-width: 700px) {
        .agent-tiers { grid-template-columns: 1fr; }
      }
      .agent-tier {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border-primary);
        background: var(--bg-secondary);
      }
      .agent-tier__header {
        padding: .5rem 1rem;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
      }
      .agent-tier__header--premium {
        background: rgba(167, 139, 250, 0.12);
        color: #a78bfa;
        border-bottom: 1px solid rgba(167, 139, 250, 0.2);
      }
      .agent-tier__header--quality {
        background: rgba(96, 165, 250, 0.1);
        color: #60a5fa;
        border-bottom: 1px solid rgba(96, 165, 250, 0.2);
      }
      .agent-tier__header--standard {
        background: rgba(129, 140, 248, 0.1);
        color: #818cf8;
        border-bottom: 1px solid rgba(129, 140, 248, 0.2);
      }
      .agent-tier__header--fast {
        background: rgba(52, 211, 153, 0.08);
        color: #34d399;
        border-bottom: 1px solid rgba(52, 211, 153, 0.2);
      }
      .agent-tier__header--economy {
        background: rgba(251, 191, 36, 0.08);
        color: #fbbf24;
        border-bottom: 1px solid rgba(251, 191, 36, 0.2);
      }
      .agent-tier__body {
        padding: 1rem;
      }
      .agent-tier__body p {
        font-size: .85rem;
        margin-bottom: .5rem;
      }
      .agent-tier__examples {
        font-size: .8rem;
        color: var(--text-tertiary);
        font-style: italic;
      }

      /* ── Getting started steps ── */
      .getting-started-steps {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin: 1.5rem 0;
      }
      .step {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.25rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-primary);
        border-radius: 10px;
      }
      .step__number {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(167, 139, 250, 0.12);
        color: var(--text-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        font-weight: 700;
        flex-shrink: 0;
        border: 1px solid rgba(167, 139, 250, 0.25);
      }
      .step__content { flex: 1; }
      .step__title {
        font-size: .9rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: .25rem;
      }
      .step__code {
        display: block;
        font-size: .8rem;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        background: rgba(0, 0, 0, 0.25);
        padding: .5rem .75rem;
        border-radius: 6px;
        color: var(--text-secondary);
        border: 1px solid var(--border-primary);
      }

      /* ── Architecture subheadings ── */
      .arch-subheading {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -.01em;
        margin: 1.75rem 0 .6rem;
      }

      /* ── Comparison table ── */
      .comparison-table-wrap {
        overflow-x: auto;
        margin-bottom: 1.5rem;
        border-radius: 10px;
        border: 1px solid var(--border-primary);
      }
      .comparison-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
      }
      .comparison-table thead tr {
        background: rgba(167, 139, 250, 0.06);
        border-bottom: 1px solid var(--border-secondary);
      }
      .comparison-table th {
        padding: .65rem 1rem;
        text-align: left;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-accent);
        white-space: nowrap;
      }
      .comparison-table td {
        padding: .65rem 1rem;
        color: var(--text-secondary);
        line-height: 1.5;
        border-bottom: 1px solid var(--border-color);
        vertical-align: top;
      }
      .comparison-table tbody tr:last-child td {
        border-bottom: none;
      }
      .comparison-table tbody tr:nth-child(even) td {
        background: rgba(255, 255, 255, 0.015);
      }
      .comparison-table td:first-child {
        font-weight: 600;
        color: var(--text-primary);
        white-space: nowrap;
      }
      .comparison-table td code {
        font-size: .8rem;
        background: var(--bg-tertiary);
        padding: .1rem .35rem;
        border-radius: 4px;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        color: #c9d1d9;
      }

      /* ── Mobile sidebar toggle ── */
      .docs-mobile-toggle {
        display: none;
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 60;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-primary);
        cursor: pointer;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
        transition: background var(--transition-fast);
      }
      .docs-mobile-toggle:hover { background: var(--bg-tertiary); }
      @media (max-width: 1023px) {
        .docs-mobile-toggle { display: flex; }
        .docs-sidebar--open {
          display: block;
          position: fixed;
          top: 56px;
          left: 0;
          width: 220px;
          height: calc(100vh - 56px);
          background: var(--bg-secondary);
          border-right: 1px solid var(--border-color);
          z-index: 55;
          padding: 16px;
        }
      }
    </style>

    <button class="docs-mobile-toggle" id="mobile-toggle" type="button" aria-label="Toggle navigation">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <script>
      const sidebar = document.getElementById('docs-sidebar');
      const mobileToggle = document.getElementById('mobile-toggle');
      const sidebarLinks = sidebar?.querySelectorAll('.docs-sidebar__link');

      // Highlight active section on scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            sidebarLinks?.forEach(link => {
              const href = link.getAttribute('href');
              link.classList.toggle('docs-sidebar__link--active',
                href === `#${entry.target.id}`);
            });
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px' });

      document.querySelectorAll('.content-section, .docs-section').forEach(s => observer.observe(s));

      // Mobile toggle
      mobileToggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('docs-sidebar--open');
      });

      // Close mobile sidebar on link click
      sidebarLinks?.forEach(link => {
        link.addEventListener('click', () => {
          sidebar?.classList.remove('docs-sidebar--open');
        });
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (sidebar?.classList.contains('docs-sidebar--open') &&
            !sidebar.contains(e.target as Node) &&
            e.target !== mobileToggle) {
          sidebar.classList.remove('docs-sidebar--open');
        }
      });
    </script>
  </body>
</html>