---
import '../../styles/global.css';

const title = 'Agentic Development & Multi-Agent Orchestration Guide — OpenCastle';
const description = 'Master agentic development with AI coding agents. Learn vibecoding best practices, multi-agent orchestration patterns, and how frameworks like OpenCastle coordinate specialist AI agents for software development.';

const introSections = [
  { id: 'what-is-it', label: 'What Is It?' },
];

const multiAgentSections = [
  { id: 'why-multi-agent', label: 'Why Multi-Agent?' },
  { id: 'orchestration', label: 'Orchestration' },
  { id: 'specialist-agents', label: 'Specialist Agents' },
  { id: 'quality-gates', label: 'Quality Gates' },
  { id: 'architecture', label: 'Architecture' },
];

const bestPracticesSections = [
  { id: 'great-prompts', label: 'Write Great Prompts' },
  { id: 'build-tools', label: 'Build Tools, Not Tasks' },
  { id: 'scope-requests', label: 'Scope Your Requests' },
  { id: 'verify', label: 'Verify, Don\'t Trust' },
  { id: 'use-context', label: 'Use Context' },
  { id: 'iterate', label: 'Iterate, Don\'t Restart' },
];

const sectionIcons: Record<string, string> = {
