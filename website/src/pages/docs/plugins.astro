        color: var(--text-secondary);
        text-decoration: none;
        transition: color var(--transition-fast), background var(--transition-fast);
      }
      .docs-header__back:hover {
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.06);
      }
      .docs-header__icon {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        object-fit: contain;
      }
      .docs-header__title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .docs-header__count {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-tertiary);
        background: var(--bg-tertiary);
        padding: 4px 10px;
        border-radius: 20px;
        letter-spacing: 0.02em;
      }

      /* ── Layout ── */
      .docs-layout {
        display: flex;
        max-width: var(--max-width);
        margin: 0 auto;
        position: relative;
      }

      /* ── Sidebar ── */
      .docs-sidebar {
        position: sticky;
        top: 56px;
        height: calc(100vh - 56px);
        width: 180px;
        flex-shrink: 0;
        padding: 24px 0 24px 24px;
        overflow-y: auto;
        display: none;
      }
      @media (min-width: 1024px) {
        .docs-sidebar { display: block; }
      }
      .docs-sidebar__list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .docs-sidebar__link {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        padding: 8px 14px;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-tertiary);
        text-decoration: none;
        border-radius: 8px;
        border: none;
        background: none;
        cursor: pointer;
        transition: color var(--transition-fast), background var(--transition-fast);
        text-align: left;
        font-family: inherit;
        line-height: 1.4;
      }
      .docs-sidebar__link:hover {
        color: var(--text-secondary);
        background: rgba(255, 255, 255, 0.04);
      }
      .docs-sidebar__link--active {
        color: var(--text-accent);
        background: rgba(167, 139, 250, 0.08);
        font-weight: 600;
      }
      .docs-sidebar__link svg {
        flex-shrink: 0;
        opacity: 0.7;
      }
      .docs-sidebar__link--active svg {
        opacity: 1;
      }

      /* ── Main ── */
      .docs-main {
        flex: 1;
        min-width: 0;
        max-width: 860px;
        padding: 32px 24px 64px;
        display: flex;
        flex-direction: column;
        gap: 0;
        position: relative;
      }
      .docs-main::before {
        content: '';
        position: fixed;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        height: 600px;
        background: var(--gradient-glow);
        pointer-events: none;
        z-index: 0;
      }
      .docs-main > * {
        position: relative;
        z-index: 1;
      }
      .docs-subtitle {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        margin-bottom: 32px;
        line-height: 1.6;
      }

      /* ── Category sections ── */
      .docs-category {
        scroll-margin-top: 72px;
        margin-bottom: 20px;
      }
      .docs-category[hidden] {
        display: none;
      }
      .docs-hero__heading {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-primary);
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 8px;
        margin-bottom: 16px;
      }

      /* ── Plugin card ── */
      .plugin-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 20px 24px;
        margin-bottom: 16px;
        transition: border-color var(--transition-fast);
      }
      .plugin-card:hover {
        border-color: rgba(255, 255, 255, 0.1);
      }
      .plugin-card__name {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
      }
      .plugin-card__name svg {
        flex-shrink: 0;
        color: var(--text-accent);
      }
      .plugin-card__desc {
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin-bottom: 12px;
        line-height: 1.5;
      }
      .plugin-card__desc a {
        color: var(--text-accent);
      }

      /* ── Plugin table ── */
      .plugin-table {
        width: 100%;
        border-collapse: collapse;
        margin: 12px 0;
        font-size: 0.8125rem;
      }
      .plugin-table th,
      .plugin-table td {
        text-align: left;
        padding: 8px 12px;
        border: 1px solid var(--border-color);
      }
      .plugin-table th {
        background: var(--bg-tertiary);
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .plugin-table td {
        color: var(--text-primary);
      }
      .plugin-table a {
        color: var(--text-accent);
        text-decoration: none;
      }
      .plugin-table a:hover {
        text-decoration: underline;
      }

      /* ── Auth badges ── */
      .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      .badge--oauth {
        background: rgba(234, 179, 8, 0.1);
        border: 1px solid rgba(234, 179, 8, 0.3);
        color: #eab308;
      }
      .badge--apikey {
        background: rgba(249, 115, 22, 0.1);
        border: 1px solid rgba(249, 115, 22, 0.3);
        color: #f97316;
      }
      .badge--none {
        color: var(--text-tertiary);
        font-size: 0.8125rem;
        font-weight: 400;
      }

      /* ── Headings inside cards ── */
      .plugin-card h4 {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-top: 16px;
        margin-bottom: 8px;
      }

      /* ── Code blocks ── */
      code {
        background: var(--bg-tertiary);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.8125rem;
        color: #c9d1d9;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
      }
      pre {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin: 8px 0 16px;
        overflow-x: auto;
      }
      pre code {
        display: block;
        padding: 16px;
        background: none;
        font-size: 0.8125rem;
        line-height: 1.5;
      }

      /* ── Callouts ── */
      .callout {
        background: rgba(234, 179, 8, 0.04);
        border: 1px solid rgba(234, 179, 8, 0.15);
        border-radius: 8px;
        padding: 12px 16px;
        margin: 12px 0;
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.5;
      }
      .callout strong {
        color: var(--text-primary);
      }
      .callout--warning {
        background: rgba(249, 115, 22, 0.04);
        border-color: rgba(249, 115, 22, 0.2);
      }
      .callout pre {
        background: rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 255, 255, 0.04);
        margin-top: 8px;
        margin-bottom: 0;
      }

      /* ── Lists in cards ── */
      .plugin-card ol,
      .plugin-card ul {
        margin: 8px 0;
        padding-left: 1.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.7;
      }
      .plugin-card li {
        margin: 4px 0;
      }
      .plugin-card p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 8px 0;
      }
      .plugin-card p strong {
        color: var(--text-primary);
      }
      .plugin-card blockquote {
        border-left: 3px solid var(--text-accent);
        padding: 8px 16px;
        margin: 12px 0;
        color: var(--text-secondary);
        font-style: italic;
        background: rgba(167, 139, 250, 0.04);
        border-radius: 0 8px 8px 0;
      }

      /* ── Misc ── */
      .setup-link {
        display: inline-block;
        color: var(--text-accent);
        font-weight: 600;
        text-decoration: none;
        font-size: 0.875rem;
      }
      .setup-link:hover {
        text-decoration: underline;
      }
      .docs-footer {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--border-color);
        font-size: 0.875rem;
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .docs-footer a {
        color: var(--text-secondary);
        text-decoration: none;
      }
      .docs-footer a:hover {
        color: var(--text-primary);
      }
      .docs-footer__sep {
        color: var(--text-tertiary);
      }
      a {
        color: var(--text-accent);
      }

      /* ── Mobile sidebar toggle ── */
      .docs-mobile-toggle {
        display: none;
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 60;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-primary);
        cursor: pointer;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
        transition: background var(--transition-fast);
      }
      .docs-mobile-toggle:hover {
        background: var(--bg-tertiary);
      }
      @media (max-width: 1023px) {
        .docs-mobile-toggle { display: flex; }
        .docs-sidebar--open {
          display: block;
          position: fixed;
          top: 56px;
          left: 0;
          width: 220px;
          height: calc(100vh - 56px);
          background: var(--bg-secondary);
          border-right: 1px solid var(--border-color);
          z-index: 55;
          padding: 16px;
        }
      }
    </style>

    <!-- Mobile sidebar toggle -->
    <button class="docs-mobile-toggle" id="mobile-toggle" type="button" aria-label="Toggle navigation">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <script>
      // ── Sidebar navigation: show/hide sections ──
      const sidebar = document.getElementById('docs-sidebar');
      const links = sidebar?.querySelectorAll('.docs-sidebar__link');
      const sections = document.querySelectorAll('[data-category]');
      const mobileToggle = document.getElementById('mobile-toggle');

      function setActiveSection(sectionId) {
        // Update active link
        links?.forEach(link => {
          link.classList.toggle('docs-sidebar__link--active',
            link.getAttribute('data-section') === sectionId);
        });

        // Show/hide sections
        if (sectionId === 'all') {
          sections.forEach(s => s.removeAttribute('hidden'));
        } else {
          sections.forEach(s => {
            if (s.id === sectionId) {
              s.removeAttribute('hidden');
            } else {
              s.setAttribute('hidden', '');
            }
          });
          // Scroll to visible section
          const target = document.getElementById(sectionId);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }

        // Close mobile sidebar
        sidebar?.classList.remove('docs-sidebar--open');

        // Update URL hash without scrolling
        history.replaceState(null, '', sectionId === 'all' ? location.pathname : `#${sectionId}`);

        // Update plugin count
        const countEl = document.getElementById('plugin-count');
        if (countEl) {
          if (sectionId === 'all') {
            countEl.textContent = '23 plugins';
          } else {
            const visible = document.querySelectorAll(`#${sectionId} .plugin-card`);
            countEl.textContent = `${visible.length} plugin${visible.length !== 1 ? 's' : ''}`;
          }
        }
      }

      // Click handler for sidebar buttons
      links?.forEach(link => {
        link.addEventListener('click', () => {
          const section = link.getAttribute('data-section');
          if (section) setActiveSection(section);
        });
      });

      // Mobile toggle
      mobileToggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('docs-sidebar--open');
      });

      // Close mobile sidebar on outside click
      document.addEventListener('click', (e) => {
        if (sidebar?.classList.contains('docs-sidebar--open') &&
            !sidebar.contains(e.target as Node) &&
            e.target !== mobileToggle) {
          sidebar.classList.remove('docs-sidebar--open');
        }
      });

      // Restore from URL hash on load
      const hash = location.hash.replace('#', '');
      if (hash && document.getElementById(hash)) {
        setActiveSection(hash);
      }
    </script>
  </body>
</html>
