---
import '../../styles/global.css';

const title = 'Use Cases — OpenCastle';
const description = 'Cookbook-style recipes for building real applications with OpenCastle. Follow step-by-step guides to build personal portfolios, SaaS dashboards, and more using your AI agent team.';

const recipes = [
  {
    id: 'portfolio',
    title: 'Build a Personal Portfolio Website',
    status: 'published' as const,
    steps: [
      { id: 'intro', label: 'Introduction' },
      { id: 'what-youll-build', label: "What you'll build" },
      { id: 'prerequisites', label: 'Prerequisites' },
      { id: 'step-1', label: 'Step 1: Initialize' },
      { id: 'step-2', label: 'Step 2: Describe project' },
      { id: 'step-3', label: 'Step 3: Review the PRD' },
      { id: 'step-4', label: 'Step 4: Preview the plan' },
      { id: 'step-5', label: 'Step 5: Execute' },
      { id: 'step-6', label: 'Step 6: Monitor' },
      { id: 'step-7', label: 'Step 7: Review & iterate' },
      { id: 'troubleshooting', label: 'Tips & Troubleshooting' },
      { id: 'whats-next', label: "What's next" },
    ],
  },
  {
    id: 'team-work',
    title: 'Team Work with Linear',
    status: 'published' as const,
    steps: [
      { id: 'team-intro', label: 'Introduction' },
      { id: 'team-what-youll-build', label: "What you'll set up" },
      { id: 'team-prerequisites', label: 'Prerequisites' },
      { id: 'team-step-1', label: 'Step 1: Initialize' },
      { id: 'team-step-2', label: 'Step 2: Connect Linear' },
      { id: 'team-step-3', label: 'Step 3: Create issues' },
      { id: 'team-step-4', label: 'Step 4: Assign & partition' },
      { id: 'team-step-5', label: 'Step 5: Execute convoy' },
      { id: 'team-step-6', label: 'Step 6: Review together' },
      { id: 'team-step-7', label: 'Step 7: Ship the PR' },
      { id: 'team-troubleshooting', label: 'Tips & Troubleshooting' },
      { id: 'team-whats-next', label: "What's next" },
    ],
  },
  {
    id: 'api-backend',
    title: 'Build a REST API Backend',
    status: 'published' as const,
    steps: [
      { id: 'api-intro', label: 'Introduction' },
      { id: 'api-what-youll-build', label: "What you'll build" },
      { id: 'api-prerequisites', label: 'Prerequisites' },
      { id: 'api-step-1', label: 'Step 1: Initialize' },
      { id: 'api-step-2', label: 'Step 2: Describe the API' },
      { id: 'api-step-3', label: 'Step 3: Review the PRD' },
      { id: 'api-step-4', label: 'Step 4: Preview the plan' },
      { id: 'api-step-5', label: 'Step 5: Execute' },
      { id: 'api-step-6', label: 'Step 6: Test the API' },
      { id: 'api-step-7', label: 'Step 7: Review & iterate' },
      { id: 'api-troubleshooting', label: 'Tips & Troubleshooting' },
      { id: 'api-whats-next', label: "What's next" },
    ],
  },
  {
    id: 'existing-project',
    title: 'Add OpenCastle to an Existing Project',
    status: 'published' as const,
    steps: [
      { id: 'existing-intro', label: 'Introduction' },
      { id: 'existing-what-youll-set-up', label: "What you'll set up" },
      { id: 'existing-prerequisites', label: 'Prerequisites' },
      { id: 'existing-step-1', label: 'Step 1: Detect your stack' },
      { id: 'existing-step-2', label: 'Step 2: Initialize OpenCastle' },
      { id: 'existing-step-3', label: 'Step 3: Review detected plugins' },
      { id: 'existing-step-4', label: 'Step 4: Write a PRD' },
      { id: 'existing-step-5', label: 'Step 5: Run with safe mode' },
      { id: 'existing-step-6', label: 'Step 6: Verify compatibility' },
      { id: 'existing-step-7', label: 'Step 7: Iterate & expand' },
      { id: 'existing-troubleshooting', label: 'Tips & Troubleshooting' },
      { id: 'existing-whats-next', label: "What's next" },
    ],
  },
];

const activeRecipe = recipes[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icon-192.png" />
  </head>
  <body>
    <header class="docs-header">
      <div class="docs-header__inner">
        <div class="docs-header__brand">
          <a href="/" class="docs-header__logo-link">
            <img class="docs-header__icon" src="/icon-192.png" alt="OpenCastle" width="28" height="28" />
          </a>
          <h1 class="docs-header__title">
            <a href="/docs/" class="docs-header__breadcrumb-link">Docs</a>
            <span class="docs-header__breadcrumb-sep">/</span>
            Use Cases
          </h1>
        </div>
      </div>
    </header>

    <div class="docs-layout">
      <nav class="docs-sidebar" id="docs-sidebar">
        <p class="docs-sidebar__label">Steps</p>
        <ul class="docs-sidebar__list">
          {activeRecipe.steps.map(step => (
            <li>
              <a class="docs-sidebar__link docs-sidebar__cmd" href={`#${step.id}`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                {step.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="docs-sidebar__divider"></div>
        <p class="docs-sidebar__label">Use Cases</p>
        <ul class="docs-sidebar__list">
          {recipes.map(r => (
            <li>
              <a class={`docs-sidebar__link ${r.id === activeRecipe.id ? 'docs-sidebar__link--active' : ''}`} href={`#${r.id}`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="13" y2="11"/></svg>
                {r.title}
                {r.status === 'coming-soon' && <span class="docs-sidebar__badge">Soon</span>}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <main class="docs-main">
        <p class="docs-subtitle">
          Cookbook-style recipes that walk you through building real applications end-to-end
          using OpenCastle's AI agent team. Each recipe covers setup, execution, iteration, and delivery.
        </p>

        <article class="recipe" id={activeRecipe.id}>
          <h2 class="recipe__title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="13" y2="11"/></svg>
            Build a Personal Portfolio Website
          </h2>

          <!-- Introduction -->
          <section class="recipe-section" id="intro">
            <h3 class="recipe-section__heading">Introduction</h3>
            <p class="recipe-section__body">
              This cookbook walks you through building a complete personal portfolio website using
              OpenCastle's AI agent team — from project setup to deployment-ready code. You'll run a
              single pipeline command that decomposes your goal, spins up a convoy of specialist agents,
              and delivers production-quality code on a feature branch ready for review.
            </p>
          </section>

          <!-- What you'll build -->
          <section class="recipe-section" id="what-youll-build">
            <h3 class="recipe-section__heading">What you'll build</h3>
            <p class="recipe-section__body">
              A personal portfolio site with four pages — responsive, dark-mode enabled,
              WCAG 2.2 AA accessible, and SEO-optimised out of the box.
            </p>

            <div class="recipe-mockup">
              <div class="recipe-mockup__chrome">
                <div class="recipe-mockup__dots"><span></span><span></span><span></span></div>
                <div class="recipe-mockup__url">localhost:3000</div>
              </div>
              <div class="recipe-mockup__body">
                <div class="mockup-nav">
                  <span class="mockup-nav__logo">JD</span>
                  <span class="mockup-nav__links">About &middot; Projects &middot; Contact</span>
                </div>
                <div class="mockup-hero">
                  <div class="mockup-hero__greeting">Hi, I'm Jane</div>
                  <div class="mockup-hero__tagline">Full-stack developer building for the web</div>
                  <div class="mockup-hero__cta">View Projects &rarr;</div>
                </div>
                <div class="mockup-section-label">Recent Projects</div>
                <div class="mockup-grid">
                  <div class="mockup-card"><div class="mockup-card__img"></div><div class="mockup-card__title"></div><div class="mockup-card__text"></div></div>
                  <div class="mockup-card"><div class="mockup-card__img"></div><div class="mockup-card__title"></div><div class="mockup-card__text"></div></div>
                  <div class="mockup-card"><div class="mockup-card__img"></div><div class="mockup-card__title"></div><div class="mockup-card__text"></div></div>
                </div>
              </div>
              <div class="recipe-mockup__pages">
                <span class="recipe-mockup__page recipe-mockup__page--active">Home</span>
                <span class="recipe-mockup__page">About</span>
                <span class="recipe-mockup__page">Projects</span>
                <span class="recipe-mockup__page">Contact</span>
              </div>
            </div>
          </section>

          <!-- Prerequisites -->
          <section class="recipe-section" id="prerequisites">
            <h3 class="recipe-section__heading">Prerequisites</h3>
            <ul class="recipe-prereq">
              <li>Node.js 22 or later (required for built-in SQLite support)</li>
              <li>Git installed and available on your PATH</li>
              <li>An AI coding IDE — VS Code with GitHub Copilot, Cursor, or Claude Code</li>
              <li>An OpenCastle-supported AI model API key (Anthropic, OpenAI, or GitHub Models)</li>
              <li>A fresh project directory (empty folder is fine)</li>
            </ul>
          </section>

          <!-- Step 1 -->
          <section class="recipe-section recipe-step" id="step-1">
            <div class="recipe-step__number">1</div>
            <h3 class="recipe-section__heading">Step 1: Initialize your project</h3>
            <p class="recipe-section__body">
              Create a new directory, initialize git and npm, then run the OpenCastle initializer.
              It detects your IDE, installs the skill library, and writes all configuration files
              into <code>.github/</code>.
            </p>
            <div class="recipe-code">
              <div class="recipe-code__header">Terminal</div>
              <pre><code>$ mkdir my-portfolio &amp;&amp; cd my-portfolio
$ git init
$ npm init -y
$ npx opencastle init</code></pre>
            </div>
            <p class="recipe-section__body">The interactive prompts will ask you to:</p>
            <ul class="recipe-section__list">
              <li><strong>Select your IDE</strong> — pick whichever you have installed (VS Code + Copilot, Cursor, or Claude Code)</li>
              <li><strong>Choose tech plugins</strong> — for this recipe, select <strong>Next.js</strong> and <strong>Vitest</strong></li>
              <li><strong>Choose team plugins</strong> — press Enter to skip (not needed for this recipe)</li>
            </ul>
            <div class="recipe-output">
              <pre><code>  ✓ Detected: VS Code
  ✓ Writing .github/instructions/
  ✓ Writing .github/skills/
  ✓ Writing .github/agents/
  ✓ Writing .github/prompts/
  ✓ OpenCastle initialized successfully</code></pre>
            </div>
            <div class="recipe-tip">
              <strong>Tip:</strong> OpenCastle scans your repo to auto-detect existing tools
              (package.json, tsconfig.json, .eslintrc, etc.) and pre-selects matching plugins.
              You can accept the defaults and customise later.
            </div>
          </section>

          <!-- Step 2 -->
          <section class="recipe-section recipe-step" id="step-2">
            <div class="recipe-step__number">2</div>
            <h3 class="recipe-section__heading">Step 2: Describe your project</h3>
            <p class="recipe-section__body">
              Run <code>npx opencastle pipeline</code> with a plain-English description of what you want
              to build. OpenCastle generates a product requirements document, validates it, decomposes
              it into an executable convoy spec, and validates that too — all automatically.
            </p>
            <div class="recipe-code">
              <div class="recipe-code__header">Terminal</div>
              <pre><code>$ npx opencastle pipeline --text "Build a personal portfolio website with a home \
  page featuring a hero section and recent projects, an about page with bio \
  and skills, a projects page with filterable cards, and a contact page with \
  a form. Use modern design, dark mode support, responsive layout, and SEO \
  optimization."</code></pre>
            </div>
            <p class="recipe-section__body">The pipeline runs five stages:</p>
            <div class="recipe-output">
              <pre><code>  ✓ Step 1/5  Generating PRD...
  ✓ Step 2/5  Validating PRD...
  ✓ Step 3/5  Generating convoy spec...
  ✓ Step 4/5  Validating convoy spec...
  ✓ Step 5/5  Auto-fixing validation issues (0 fixes applied)

  PRD written to: .opencastle/prd/portfolio.md
  Convoy spec written to: .opencastle/convoys/portfolio.convoy.yml
  Tasks: 12  ·  Estimated agents: 4  ·  Max parallelism: 3</code></pre>
            </div>
            <div class="recipe-tip">
              <strong>Tip:</strong> Add <code>--dry-run</code> to preview the PRD generation prompt
              without executing it.
            </div>
          </section>

          <!-- Step 3 -->
          <section class="recipe-section recipe-step" id="step-3">
            <div class="recipe-step__number">3</div>
            <h3 class="recipe-section__heading">Step 3: Review the generated PRD</h3>
            <p class="recipe-section__body">
              Open <code>.opencastle/prd/portfolio.md</code> to review the product requirements document.
              The PRD is the single source of truth — editing it is how you steer the entire project.
              The convoy spec is auto-generated from the PRD, so you rarely need to touch it directly.
            </p>
            <div class="recipe-code">
              <div class="recipe-code__header">.opencastle/prd/portfolio.md</div>
              <pre><code># Personal Portfolio Website

## Overview
A responsive personal portfolio website with four pages,
dark-mode support, and SEO optimisation.

## Pages

### Home
- Hero section with name, tagline, and call-to-action button
- Recent projects grid (3 most recent)
- Smooth scroll to sections

### About
- Bio paragraph with professional photo placeholder
- Skills grid organised by category
- Social links (GitHub, LinkedIn, Twitter)

### Projects
- Filterable project cards with tags
- Each card: title, description, screenshot, tech stack, links
- Filter by technology tag

### Contact
- Accessible contact form (name, email, message)
- Client-side validation with inline error messages
- Server-side validation endpoint

## Non-functional Requirements
- Responsive: mobile, tablet, desktop breakpoints
- Dark mode with system preference detection
- WCAG 2.2 AA accessible
- SEO: meta tags, Open Graph, sitemap.xml
- Core Web Vitals: LCP &lt; 2.5s, CLS &lt; 0.1</code></pre>
            </div>
            <div class="recipe-tip">
              <strong>Tip:</strong> This PRD is yours to edit. Add acceptance criteria, adjust scope,
              or remove pages entirely. When you re-run the pipeline, the convoy spec is
              regenerated from the updated PRD automatically.
            </div>
          </section>

          <!-- Step 4 -->
          <section class="recipe-section recipe-step" id="step-4">
            <div class="recipe-step__number">4</div>
            <h3 class="recipe-section__heading">Step 4: Preview the execution plan</h3>
            <p class="recipe-section__body">
              Run the convoy with <code>--dry-run</code> to see the dependency graph and execution
              order without writing any code.
            </p>
            <div class="recipe-code">
              <div class="recipe-code__header">Terminal</div>
              <pre><code>$ npx opencastle run -f .opencastle/convoys/portfolio.convoy.yml --dry-run</code></pre>
            </div>
            <div class="recipe-output">
              <pre><code>  Convoy: portfolio  ·  12 tasks  ·  dry-run mode

  Execution plan (topological order):
  Phase 1  [parallel]  setup-project
  Phase 2  [parallel]  home-page, about-page, projects-page, contact-page
  Phase 3  [parallel]  seo-meta, dark-mode, accessibility-audit
  Phase 4  [parallel]  e2e-smoke, integration-tests
  Phase 5  [serial]    final-review

  Agents required: developer (x3), reviewer (x1)
  No code will be written in dry-run mode.</code></pre>
            </div>
          </section>

          <!-- Step 5 -->
          <section class="recipe-section recipe-step" id="step-5">
            <div class="recipe-step__number">5</div>
            <h3 class="recipe-section__heading">Step 5: Execute the convoy</h3>
            <p class="recipe-section__body">
              Remove <code>--dry-run</code> to start execution. Each task runs in an isolated
              git worktree so agents work safely in parallel without conflicts. Tasks that
              pass their gates are merged back automatically; failed tasks go to the dead-letter queue.
            </p>
            <div class="recipe-code">
              <div class="recipe-code__header">Terminal</div>
              <pre><code>$ npx opencastle run -f .opencastle/convoys/portfolio.convoy.yml</code></pre>
            </div>
            <div class="recipe-output">
              <pre><code>  ◎ Convoy started  ·  portfolio  ·  convoy_id=cvy_3kx9

  ✓ [Phase 1]  setup-project         agent=developer  2m 14s
  ✓ [Phase 2]  home-page             agent=developer  4m 02s
  ✓ [Phase 2]  about-page            agent=developer  3m 48s
  ✓ [Phase 2]  projects-page         agent=developer  4m 31s
  ✓ [Phase 2]  contact-page          agent=developer  3m 11s
  ↻ [Phase 3]  seo-meta              retrying (1/3)...
  ✓ [Phase 3]  seo-meta              agent=developer  2m 05s
  ✓ [Phase 4]  final-review          agent=reviewer   1m 44s

  ✓ Convoy complete  ·  12/12 tasks passed  ·  total 28m 42s
  Branch: feature/portfolio-convoy-cvy_3kx9</code></pre>
            </div>
            <div class="recipe-tip">
              <strong>Note:</strong> If your machine sleeps or the process is interrupted, resume any time
              with <code>npx opencastle run -f .opencastle/convoys/portfolio.convoy.yml --resume</code>.
              Use <code>--retry-failed</code> to re-run only tasks that failed.
            </div>
          </section>

          <!-- Step 6 -->
          <section class="recipe-section recipe-step" id="step-6">
            <div class="recipe-step__number">6</div>
            <h3 class="recipe-section__heading">Step 6: Monitor progress</h3>
            <p class="recipe-section__body">
              The local dashboard starts automatically when the convoy runs. Open
              <code>http://localhost:4321</code> in your browser to see:
            </p>
            <ul class="recipe-section__list">
              <li>Live task status grid (queued → running → passed / failed)</li>
              <li>Per-agent activity log and retry history</li>
              <li>Gate results (lint, type-check, tests) per task</li>
              <li>Dead-letter queue for tasks that exhausted retries</li>
            </ul>
            <div class="recipe-tip">
              <strong>Tip:</strong> For real-time streaming output directly in your terminal,
              add <code>--watch</code> when running the convoy:
              <code>npx opencastle run -f .opencastle/convoys/portfolio.convoy.yml --watch</code>.
            </div>
          </section>

          <!-- Step 7 -->
          <section class="recipe-section recipe-step" id="step-7">
            <div class="recipe-step__number">7</div>
            <h3 class="recipe-section__heading">Step 7: Review and iterate</h3>
            <p class="recipe-section__body">
              The convoy leaves you on the feature branch with all generated code.
              Review the output, then use your IDE’s AI chat for quick refinements
              without re-running a full convoy:
            </p>
            <div class="recipe-tabs" data-tabs>
              <div class="recipe-tabs__header">
                <button class="recipe-tabs__tab recipe-tabs__tab--active" data-tab="vscode" type="button">VS Code + Copilot</button>
                <button class="recipe-tabs__tab" data-tab="cursor" type="button">Cursor</button>
                <button class="recipe-tabs__tab" data-tab="claude" type="button">Claude Code</button>
              </div>
              <div class="recipe-tabs__panel recipe-tabs__panel--active" data-panel="vscode">
                <pre><code># Open Copilot Chat (Ctrl+Shift+I / Cmd+Shift+I)
# Use the /quick-refinement prompt template:
"Polish the hero section animation — fade in from below
 rather than appear instantly. Respect prefers-reduced-motion."</code></pre>
              </div>
              <div class="recipe-tabs__panel" data-panel="cursor">
                <pre><code># Open Composer (Cmd+I / Ctrl+I)
# Describe the change:
"Polish the hero section animation — fade in from below
 rather than appear instantly. Respect prefers-reduced-motion."</code></pre>
              </div>
              <div class="recipe-tabs__panel" data-panel="claude">
                <pre><code># In your terminal, describe the change:
$ claude "Polish the hero section animation — fade in from below \
  rather than appear instantly. Respect prefers-reduced-motion."</code></pre>
              </div>
            </div>
            <p class="recipe-section__body">
              When you’re satisfied with the result, push the branch and open a pull request:
            </p>
            <div class="recipe-code">
              <div class="recipe-code__header">Terminal</div>
              <pre><code>$ git push -u origin feature/portfolio-convoy-cvy_3kx9
$ gh pr create --title "feat: personal portfolio (convoy cvy_3kx9)"</code></pre>
            </div>
          </section>

          <!-- Tips & Troubleshooting -->
          <section class="recipe-section" id="troubleshooting">
            <h3 class="recipe-section__heading">Tips &amp; Troubleshooting</h3>
            <div class="recipe-troubleshooting">
              <div class="recipe-troubleshooting__item">
                <p class="recipe-troubleshooting__problem">Pipeline fails at validation</p>
                <p class="recipe-troubleshooting__solution">
                  The PRD didn’t pass the validation gate — usually because a section is too vague
                  or missing acceptance criteria. Open <code>.opencastle/prd/portfolio.md</code>,
                  add more detail to the flagged section (e.g. specify exact form fields, layout
                  breakpoints, or expected behaviour), then commit and push. Re-run
                  <code>npx opencastle pipeline</code> — it regenerates the convoy spec from the
                  updated PRD automatically.
                </p>
              </div>
              <div class="recipe-troubleshooting__item">
                <p class="recipe-troubleshooting__problem">The “contact-page” task keeps failing</p>
                <p class="recipe-troubleshooting__solution">
                  Check the dead-letter queue in the dashboard or run
                  <code>npx opencastle run --dlq-show</code> to see the error and which gate failed.
                  The root cause is usually an underspecified requirement. Open
                  <code>.opencastle/prd/portfolio.md</code>, expand the Contact section with more detail —
                  for example, list exact form fields, validation rules, and the expected server-side
                  endpoint behaviour. Commit, push, and re-run the pipeline. The convoy regenerates
                  and retries only the failed task.
                </p>
              </div>
              <div class="recipe-troubleshooting__item">
                <p class="recipe-troubleshooting__problem">Need to change scope mid-run</p>
                <p class="recipe-troubleshooting__solution">
                  Pause the convoy: <code>npx opencastle run --pause</code>. Edit the PRD to adjust
                  scope, then re-run the pipeline to regenerate the convoy spec. Resume with
                  <code>npx opencastle run --resume</code>. Already-completed tasks are not re-run.
                </p>
              </div>
              <div class="recipe-troubleshooting__item">
                <p class="recipe-troubleshooting__problem">Want to run overnight</p>
                <p class="recipe-troubleshooting__solution">
                  Convoy execution is crash-safe by design. Each task writes its state to
                  <code>.opencastle/convoy.db</code> before and after execution. If your machine
                  sleeps or the process is killed, <code>--resume</code> picks up exactly where
                  it left off.
                </p>
              </div>
            </div>
          </section>

          <!-- What's next -->
          <section class="recipe-section" id="whats-next">
            <h3 class="recipe-section__heading">What's next</h3>
            <p class="recipe-section__body">Now that you've shipped a portfolio, try these next steps:</p>
            <ul class="recipe-section__list">
