        margin: 16px 14px 12px 14px;
      }
      .docs-sidebar__label {
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0 14px 4px;
      }

      /* ── Main ── */
      .docs-main {
        flex: 1;
        min-width: 0;
        max-width: 860px;
        padding: 32px 24px 64px;
        display: flex;
        flex-direction: column;
        gap: 0;
        position: relative;
      }
      .docs-main::before {
        content: '';
        position: fixed;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        height: 600px;
        background: var(--gradient-glow);
        pointer-events: none;
        z-index: 0;
      }
      .docs-main > * { position: relative; z-index: 1; }
      .docs-subtitle {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        margin-bottom: 32px;
        line-height: 1.6;
      }

      /* ── Recipe article ── */
      .recipe { display: flex; flex-direction: column; gap: 0; }
      .recipe__title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.375rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 24px;
        scroll-margin-top: 72px;
      }
      .recipe__title svg { flex-shrink: 0; color: var(--text-accent); }

      /* ── Recipe section ── */
      .recipe-section { margin-bottom: 32px; scroll-margin-top: 72px; }
      .recipe-section__heading {
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border-color);
      }
      .recipe-section__body {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.7;
        margin-bottom: 12px;
      }
      .recipe-section__body:last-child { margin-bottom: 0; }
      .recipe-section__list {
        list-style: none;
        padding: 0;
        margin: 12px 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .recipe-section__list li {
        position: relative;
        padding: 8px 12px 8px 28px;
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.6;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 6px;
      }
      .recipe-section__list li::before {
        content: '';
        position: absolute;
        left: 10px;
        top: 16px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(167, 139, 250, 0.5);
      }
      .recipe-section__list li strong { color: var(--text-primary); }
      .recipe-section__list li a { color: var(--text-accent); text-decoration: none; }
      .recipe-section__list li a:hover { text-decoration: underline; }

      /* ── Recipe step (numbered) ── */
      .recipe-step {
        position: relative;
        padding-left: 52px;
        border-left: 2px solid var(--border-color);
        padding-bottom: 8px;
        margin-left: 16px;
      }
      .recipe-step__number {
        position: absolute;
        left: -20px;
        top: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(167, 139, 250, 0.12);
        border: 2px solid rgba(167, 139, 250, 0.3);
        color: var(--text-accent);
        font-size: 0.875rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      /* ── Recipe code block ── */
      .recipe-code {
        margin: 12px 0 16px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border-color);
      }
      .recipe-code__header {
        background: var(--bg-tertiary);
        border-bottom: 1px solid var(--border-color);
        padding: 8px 16px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      .recipe-code pre {
        background: var(--bg-secondary);
        border: none;
        border-radius: 0;
        margin: 0;
      }
      .recipe-code pre code {
        display: block;
        padding: 16px;
        font-size: 0.8125rem;
        line-height: 1.6;
        color: #c9d1d9;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        background: none;
      }

      /* ── Recipe output block (dimmed) ── */
      .recipe-output { margin: 12px 0 16px; }
      .recipe-output pre {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        margin: 0;
        overflow-x: auto;
      }
      .recipe-output pre code {
        display: block;
        padding: 16px;
        font-size: 0.8125rem;
        line-height: 1.6;
        color: var(--text-tertiary);
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        background: none;
      }

      /* ── Recipe tip box (purple left border) ── */
      .recipe-tip {
        margin: 12px 0 16px;
        padding: 12px 16px;
        border-left: 3px solid rgba(167, 139, 250, 0.5);
        background: rgba(167, 139, 250, 0.05);
        border-radius: 0 8px 8px 0;
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
      }
      .recipe-tip strong { color: var(--text-accent); }
      .recipe-tip code {
        font-size: 0.8125rem;
        background: rgba(167, 139, 250, 0.08);
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
        color: var(--text-accent);
      }

      /* ── Prerequisites list (checkmark bullets) ── */
      .recipe-prereq {
        list-style: none;
        padding: 0;
        margin: 12px 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .recipe-prereq li {
        position: relative;
        padding: 10px 14px 10px 38px;
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.5;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
      }
      .recipe-prereq li::before {
        content: '✓';
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(167, 139, 250, 0.7);
        font-size: 0.875rem;
        font-weight: 700;
      }

      /* ── Troubleshooting grid ── */
      .recipe-troubleshooting { display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }
      .recipe-troubleshooting__item {
        padding: 14px 16px;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 10px;
      }
      .recipe-troubleshooting__problem {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 6px;
      }
      .recipe-troubleshooting__problem::before { content: '⚠ '; color: rgba(251, 191, 36, 0.7); }
      .recipe-troubleshooting__solution {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
      }
      .recipe-troubleshooting__solution code { font-size: 0.8125rem; }

      /* ── Browser mockup ── */
      .recipe-mockup {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        margin: 16px 0;
        background: #0d0d14;
      }
      .recipe-mockup__chrome {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        background: var(--bg-tertiary);
        border-bottom: 1px solid var(--border-color);
      }
      .recipe-mockup__dots { display: flex; gap: 6px; }
      .recipe-mockup__dots span { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.1); }
      .recipe-mockup__dots span:first-child { background: #ff5f57; }
      .recipe-mockup__dots span:nth-child(2) { background: #ffbd2e; }
      .recipe-mockup__dots span:last-child { background: #28c840; }
      .recipe-mockup__url {
        flex: 1;
        text-align: center;
        font-size: 0.75rem;
        color: var(--text-tertiary);
        background: rgba(255,255,255,0.04);
        border-radius: 4px;
        padding: 4px 12px;
      }
      .recipe-mockup__body { padding: 24px; min-height: 260px; }
      .mockup-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
      .mockup-nav__logo {
        width: 32px; height: 32px; border-radius: 50%;
        background: rgba(167,139,250,0.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem; font-weight: 700; color: var(--text-accent);
      }
      .mockup-nav__links { font-size: 0.75rem; color: var(--text-tertiary); }
      .mockup-hero { text-align: center; margin-bottom: 32px; }
      .mockup-hero__greeting { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
      .mockup-hero__tagline { font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 12px; }
      .mockup-hero__cta {
        display: inline-block; font-size: 0.75rem; padding: 6px 16px; border-radius: 6px;
        background: rgba(167,139,250,0.15); color: var(--text-accent); border: 1px solid rgba(167,139,250,0.3);
      }
      .mockup-section-label {
        font-size: 0.6875rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--text-tertiary); margin-bottom: 12px;
      }
      .mockup-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .mockup-card {
        background: rgba(255,255,255,0.03); border: 1px solid var(--border-color);
        border-radius: 8px; padding: 10px;
      }
      .mockup-card__img { height: 48px; background: rgba(167,139,250,0.06); border-radius: 4px; margin-bottom: 8px; }
      .mockup-card__title { height: 8px; width: 60%; background: rgba(255,255,255,0.1); border-radius: 4px; margin-bottom: 6px; }
      .mockup-card__text { height: 6px; width: 80%; background: rgba(255,255,255,0.05); border-radius: 4px; }
      .mockup-card--text .mockup-card__title {
        height: auto; width: auto; background: none;
        font-size: 0.6875rem; font-weight: 600; color: var(--text-accent); margin-bottom: 8px;
      }
      .mockup-card--text .mockup-card__text {
        height: auto; width: auto; background: none;
        font-size: 0.6875rem; color: var(--text-tertiary); line-height: 1.5;
      }
      .recipe-mockup__body pre {
        margin: 0; background: none; border: none; border-radius: 0;
      }
      .recipe-mockup__body pre code {
        display: block; padding: 0;
        font-size: 0.75rem; line-height: 1.6;
        color: var(--text-tertiary);
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        background: none; white-space: pre;
      }
      .recipe-mockup__pages {
        display: flex; gap: 0; border-top: 1px solid var(--border-color);
      }
      .recipe-mockup__page {
        flex: 1; text-align: center; padding: 8px 0; font-size: 0.6875rem; font-weight: 500;
        color: var(--text-tertiary); border-right: 1px solid var(--border-color);
      }
      .recipe-mockup__page:last-child { border-right: none; }
      .recipe-mockup__page--active { color: var(--text-accent); background: rgba(167,139,250,0.05); }

      /* ── IDE tabs ── */
      .recipe-tabs { margin: 12px 0 16px; border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden; }
      .recipe-tabs__header { display: flex; background: var(--bg-tertiary); border-bottom: 1px solid var(--border-color); }
      .recipe-tabs__tab {
        padding: 8px 16px; font-size: 0.8125rem; font-weight: 500; color: var(--text-tertiary);
        cursor: pointer; border: none; background: none; border-bottom: 2px solid transparent;
        transition: color var(--transition-fast), border-color var(--transition-fast); font-family: inherit;
      }
      .recipe-tabs__tab:hover { color: var(--text-secondary); }
      .recipe-tabs__tab--active { color: var(--text-accent); border-bottom-color: var(--text-accent); }
      .recipe-tabs__panel { display: none; }
      .recipe-tabs__panel--active { display: block; }
      .recipe-tabs__panel pre { margin: 0; border: none; border-radius: 0; }
      .recipe-tabs__panel pre code { display: block; padding: 16px; background: var(--bg-secondary); font-size: 0.8125rem; line-height: 1.6; color: #c9d1d9; font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace; }

      /* ── Sidebar badge ── */
      .docs-sidebar__badge {
        font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
        padding: 1px 6px; border-radius: 4px; margin-left: auto;
        background: rgba(255,255,255,0.06); color: var(--text-tertiary);
      }

      /* ── Global code/pre ── */
      code {
        background: var(--bg-tertiary);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.8125rem;
        color: #c9d1d9;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
      }
      pre {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin: 8px 0 16px;
        overflow-x: auto;
      }
      pre code {
        display: block;
        padding: 16px;
        background: none;
        font-size: 0.8125rem;
        line-height: 1.5;
      }
      a { color: var(--text-accent); }

      /* ── Footer ── */
      .footer {
        border-top: 1px solid var(--border-color);
        background: var(--bg-secondary);
        margin-top: 48px;
      }
      .footer__inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }
      .footer__copyright { font-size: 0.8125rem; color: var(--text-tertiary); }
      .footer__links { display: flex; list-style: none; gap: 16px; padding: 0; }
      .footer__links a {
        font-size: 0.8125rem;
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color var(--transition-fast);
      }
      .footer__links a:hover { color: var(--text-accent); }

      /* ── Mobile sidebar toggle ── */
      .docs-mobile-toggle {
        display: none;
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 60;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-primary);
        cursor: pointer;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
        transition: background var(--transition-fast);
      }
      .docs-mobile-toggle:hover { background: var(--bg-tertiary); }
      @media (max-width: 1023px) {
        .docs-mobile-toggle { display: flex; }
        .docs-sidebar--open {
          display: block;
          position: fixed;
          top: 56px;
          left: 0;
          width: 220px;
          height: calc(100vh - 56px);
          background: var(--bg-secondary);
          border-right: 1px solid var(--border-color);
          z-index: 55;
          padding: 16px;
        }
      }
    </style>

    <!-- Mobile sidebar toggle -->
    <button class="docs-mobile-toggle" id="mobile-toggle" type="button" aria-label="Toggle navigation">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <script>
      const sidebar = document.getElementById('docs-sidebar');
      const mobileToggle = document.getElementById('mobile-toggle');

      mobileToggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('docs-sidebar--open');
      });

      document.addEventListener('click', (e) => {
        if (sidebar?.classList.contains('docs-sidebar--open') &&
            !sidebar.contains(e.target as Node) &&
            e.target !== mobileToggle) {
          sidebar.classList.remove('docs-sidebar--open');
        }
      });

      sidebar?.querySelectorAll('a[href^="#"]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const id = (link as HTMLAnchorElement).getAttribute('href')?.replace('#', '');
          if (id) {
            const target = document.getElementById(id);
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
              history.replaceState(null, '', `#${id}`);
            }
          }
          sidebar?.classList.remove('docs-sidebar--open');
        });
      });

      const hash = location.hash.replace('#', '');
      if (hash) {
        const target = document.getElementById(hash);
        if (target) {
          requestAnimationFrame(() => {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        }
      }

      // Tab switching
      document.querySelectorAll('.recipe-tabs').forEach(tabs => {
        const tabBtns = tabs.querySelectorAll('.recipe-tabs__tab');
        const panels = tabs.querySelectorAll('.recipe-tabs__panel');
        tabBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const target = (btn as HTMLButtonElement).getAttribute('data-tab');
            tabBtns.forEach(b => b.classList.remove('recipe-tabs__tab--active'));
            panels.forEach(p => p.classList.remove('recipe-tabs__panel--active'));
            btn.classList.add('recipe-tabs__tab--active');
            tabs.querySelector(`[data-panel="${target}"]`)?.classList.add('recipe-tabs__panel--active');
          });
        });
      });
    </script>
  </body>
</html>
