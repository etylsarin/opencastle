---
import '../../styles/global.css';

const title = 'Docs — OpenCastle';
const description = 'OpenCastle documentation. CLI reference, plugin setup guides, and everything you need to configure your AI agent team.';

const pages = [
  {
    href: '/docs/agentic-development',
    title: 'Agentic Development',
    description: 'Guide to agentic development and multi-agent orchestration. Vibecoding best practices, prompt patterns, specialist agents, quality gates, and how to coordinate AI agent teams.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/><line x1="9" y1="21" x2="15" y2="21"/></svg>`,
    sidebarIcon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/><line x1="9" y1="21" x2="15" y2="21"/></svg>`,
    badge: 'guide',
  },
  {
    href: '/docs/cli',
    title: 'CLI Reference',
    description: 'Complete reference for every opencastle command — init, update, eject, destroy, run, plan, dashboard, and doctor.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    sidebarIcon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    badge: '15 commands',
  },
  {
    href: '/docs/prompts',
    title: 'Prompt Templates',
    description: 'Ready-to-use prompt templates for the Team Lead agent. Brainstorm ideas, implement features, fix bugs, resolve PR comments, and generate task specs.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    sidebarIcon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    badge: '8 prompts',
  },
  {
    href: '/docs/plugins',
    title: 'Plugin Setup Guide',
    description: 'Configure plugins for your AI coding agents. Each plugin bundles skills, optional MCP server configs, and agent tool mappings.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>`,
    sidebarIcon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>`,
    badge: '50 plugins',
  },
  {
    href: '/docs/use-cases',
    title: 'Use Cases',
    description: 'Cookbook-style recipes for common projects. Follow step-by-step guides to build real applications with your AI agent team.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="13" y2="11"/></svg>`,
    sidebarIcon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="13" y2="11"/></svg>`,
    badge: '1 recipe',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icon-192.png" />
  </head>
  <body>
    <header class="docs-header">
      <div class="docs-header__inner">
        <div class="docs-header__brand">
          <a href="/" class="docs-header__logo-link">
            <img class="docs-header__icon" src="/icon-192.png" alt="OpenCastle" width="28" height="28" />
          </a>
          <h1 class="docs-header__title">Docs</h1>
        </div>
      </div>
    </header>

    <div class="docs-layout">
      <!-- Sidebar Navigation -->
      <nav class="docs-sidebar">
        <ul class="docs-sidebar__list">
          <li>
            <a class="docs-sidebar__link docs-sidebar__link--active" href="#quick-start">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Quick Start
            </a>
          </li>
          <li>
            <a class="docs-sidebar__link" href="#demo-video">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Demo Video
            </a>
          </li>
        </ul>

        <div class="docs-sidebar__divider"></div>
        <p class="docs-sidebar__label">Pages</p>
        <ul class="docs-sidebar__list">
          {pages.map((page) => (
            <li>
              <a class="docs-sidebar__link" href={page.href}>
                <Fragment set:html={page.sidebarIcon} />
                {page.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <main class="docs-main">
        <section class="docs-hero">
          <h2 class="docs-hero__heading">OpenCastle Documentation</h2>
          <p class="docs-hero__sub">Everything you need to install, configure, and run your AI agent team.</p>
        </section>

        <!-- Demo Video -->
        <section class="demo-video-section" id="demo-video">
          <h3 class="demo-video-section__heading">See it in action</h3>
          <div class="demo-video-section__wrapper">
            <video
              class="demo-video-section__player"
              controls
              playsinline
              preload="metadata"
              webkit-playsinline
            >
              <source src="/opencastle-demo.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </section>

        <!-- Quick start -->
        <section class="quickstart" id="quick-start">
          <h3 class="quickstart__heading">Quick Start</h3>
          <div class="quickstart__steps">
            <!-- Step 1: Install -->
            <div class="quickstart__step">
              <span class="quickstart__num">1</span>
              <div>
                <p class="quickstart__label">Install</p>
                <code class="quickstart__code">npx opencastle init</code>
              </div>
            </div>

            <!-- Step 2: Select your stack -->
            <div class="quickstart__step">
              <span class="quickstart__num">2</span>
              <div>
                <p class="quickstart__label">Select your stack</p>
                <p class="quickstart__desc">Pick your IDE, frameworks, and team tools in the interactive wizard.</p>
              </div>
            </div>
          </div>

          <!-- Single IDE switcher for steps 3–5 -->
          <div class="quickstart__ide-switcher">
            <div class="quickstart__tabs" role="tablist" aria-label="IDE selection">
              <button class="quickstart__tab quickstart__tab--active" role="tab" aria-selected="true" data-ide="vscode">VS Code</button>
              <button class="quickstart__tab" role="tab" aria-selected="false" data-ide="cursor">Cursor</button>
              <button class="quickstart__tab" role="tab" aria-selected="false" data-ide="claude-code">Claude Code</button>
              <button class="quickstart__tab" role="tab" aria-selected="false" data-ide="opencode">OpenCode</button>
            </div>
          </div>

          <div class="quickstart__steps">
            <!-- Step 3: Open your IDE -->
            <div class="quickstart__step">
              <span class="quickstart__num">3</span>
              <div>
                <p class="quickstart__label">Open your IDE</p>
                <div class="quickstart__panels" data-panel-group="step3">
                  <div class="quickstart__panel quickstart__panel--active" data-ide="vscode" role="tabpanel">
                    <p class="quickstart__desc">Open VS Code and reload the window (<code class="quickstart__code">Cmd+Shift+P</code> &rarr; <em>&ldquo;Developer: Reload Window&rdquo;</em>). This loads the OpenCastle agents, skills, and instructions.</p>
                  </div>
                  <div class="quickstart__panel" data-ide="cursor" role="tabpanel" hidden>
                    <p class="quickstart__desc">Open Cursor &mdash; the rules will be loaded automatically from <code class="quickstart__code">.cursor/rules/</code>.</p>
                  </div>
                  <div class="quickstart__panel" data-ide="claude-code" role="tabpanel" hidden>
                    <p class="quickstart__desc">Run <code class="quickstart__code">claude</code> in your terminal from the project root. CLAUDE.md will be auto-loaded.</p>
                  </div>
                  <div class="quickstart__panel" data-ide="opencode" role="tabpanel" hidden>
                    <p class="quickstart__desc">Run <code class="quickstart__code">opencode</code> in your terminal from the project root. AGENTS.md will be auto-loaded.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Step 4: Bootstrap your project -->
            <div class="quickstart__step">
              <span class="quickstart__num">4</span>
              <div>
                <p class="quickstart__label">Bootstrap your project</p>
                <p class="quickstart__desc">If you have an existing codebase, run the bootstrap prompt first. It scans your project and generates tailored configuration.</p>
                <div class="quickstart__panels" data-panel-group="step4">
                  <div class="quickstart__panel quickstart__panel--active" data-ide="vscode" role="tabpanel">
                    <p class="quickstart__desc">In Copilot Chat, select the <strong>Team Lead</strong> agent and run the <strong>Bootstrap Customizations</strong> prompt. The Team Lead will scan your project, detect your tech stack, and generate tailored configuration files in <code class="quickstart__code">.opencastle/</code>.</p>
                  </div>
                  <div class="quickstart__panel" data-ide="cursor" role="tabpanel" hidden>
                    <p class="quickstart__desc">Start a new chat and ask: <em>&ldquo;Run the Bootstrap Customizations prompt&rdquo;</em>. The Team Lead will scan your project, detect your tech stack, and generate tailored configuration files in <code class="quickstart__code">.opencastle/</code>.</p>
                  </div>
                  <div class="quickstart__panel" data-ide="claude-code" role="tabpanel" hidden>
                    <p class="quickstart__desc">Run the <code class="quickstart__code">/bootstrap-customizations</code> command. The Team Lead will scan your project, detect your tech stack, and generate tailored configuration files in <code class="quickstart__code">.opencastle/</code>.</p>
                  </div>
                  <div class="quickstart__panel" data-ide="opencode" role="tabpanel" hidden>
                    <p class="quickstart__desc">Run the <code class="quickstart__code">bootstrap-customizations</code> prompt. The Team Lead will scan your project, detect your tech stack, and generate tailored configuration files in <code class="quickstart__code">.opencastle/</code>.</p>
                  </div>
                </div>
                <p class="quickstart__hint">Skip this step for brand-new projects &mdash; there&rsquo;s nothing to detect yet.</p>
              </div>
            </div>

            <!-- Step 5: Start building -->
            <div class="quickstart__step">
              <span class="quickstart__num">5</span>
              <div>
                <p class="quickstart__label">Start building</p>
                <p class="quickstart__desc">You&rsquo;re ready to go. Choose how you want to work:</p>

                <div class="quickstart__options">
                  <!-- Option A: Interactive -->
                  <div class="quickstart__option">
                    <span class="quickstart__option-letter">A</span>
                    <div>
                      <p class="quickstart__option-title">Interactive <span class="quickstart__option-badge">recommended</span></p>
                      <p class="quickstart__desc">Ask the <strong>Team Lead</strong> to implement a feature, fix a bug, or brainstorm ideas. It will decompose the work, delegate to specialist agents, and deliver a PR.</p>
                      <div class="quickstart__panels" data-panel-group="step5a">
                        <div class="quickstart__panel quickstart__panel--active" data-ide="vscode" role="tabpanel">
                          <p class="quickstart__desc">In Copilot Chat, select the <strong>Team Lead</strong> agent and run the <strong>Implement Feature</strong> prompt. Describe what you want to build.</p>
                        </div>
                        <div class="quickstart__panel" data-ide="cursor" role="tabpanel" hidden>
                          <p class="quickstart__desc">Start a new chat and describe what you want to build. The Team Lead rules will activate automatically.</p>
                        </div>
                        <div class="quickstart__panel" data-ide="claude-code" role="tabpanel" hidden>
                          <p class="quickstart__desc">Run the <code class="quickstart__code">/implement-feature</code> command and describe what you want to build.</p>
                        </div>
                        <div class="quickstart__panel" data-ide="opencode" role="tabpanel" hidden>
                          <p class="quickstart__desc">Run the <code class="quickstart__code">implement-feature</code> prompt and describe what you want to build.</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Option B: Convoy -->
                  <div class="quickstart__option">
                    <span class="quickstart__option-letter">B</span>
                    <div>
                      <p class="quickstart__option-title">Convoy <span class="quickstart__option-badge">autonomous</span></p>
                      <p class="quickstart__desc">For larger tasks, generate a convoy spec first, review it, then execute it autonomously. The convoy engine runs tasks in parallel using isolated git worktrees.</p>
                      <div class="quickstart__substeps">
                        <div class="quickstart__substep">
                          <span class="quickstart__substep-num">1</span>
                          <p class="quickstart__desc"><strong>Generate:</strong> Describe your goal and run the start command: <code class="quickstart__code">npx opencastle start -t "Add user reviews to the place detail page"</code>. It generates a PRD, validates it, produces a <code class="quickstart__code">.convoy.yml</code> spec, and validates that too &mdash; all in one command.</p>
                        </div>
                        <div class="quickstart__substep">
                          <span class="quickstart__substep-num">2</span>
                          <p class="quickstart__desc"><strong>Review:</strong> Open the generated YAML file and verify the task breakdown, file partitions, and dependency order. You can also validate it: <code class="quickstart__code">npx opencastle validate .opencastle/convoys/your-spec.convoy.yml</code></p>
                        </div>
                        <div class="quickstart__substep">
                          <span class="quickstart__substep-num">3</span>
                          <p class="quickstart__desc"><strong>Execute:</strong> <code class="quickstart__code">npx opencastle run -f .opencastle/convoys/your-spec.convoy.yml</code></p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </section>

        <!-- Doc pages grid -->
        <section class="docs-grid">
          {pages.map((page) => (
            <a href={page.href} class="doc-card">
              <div class="doc-card__icon" set:html={page.icon} />
              <div class="doc-card__body">
                <div class="doc-card__header">
                  <h3 class="doc-card__title">{page.title}</h3>
                  <span class="doc-card__badge">{page.badge}</span>
                </div>
                <p class="doc-card__desc">{page.description}</p>
              </div>
              <svg class="doc-card__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ))}
        </section>

      </main>
    </div>

    <footer class="footer">
      <div class="footer__inner">
        <span class="footer__copyright">
          MIT License · Filip Mares · 2026
        </span>
        <ul class="footer__links">
          <li><a href="/docs/">Docs</a></li>
          <li><a href="https://github.com/etylsarin/opencastle" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="https://github.com/etylsarin/opencastle/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a></li>
        </ul>
      </div>
    </footer>

    <style>
      :root {
        --bg-primary: #0a0a0f;
        --bg-secondary: #111118;
        --bg-tertiary: #1a1a24;
        --border-primary: #1e1e2e;
        --border-secondary: #2a2a3a;
        --border-color: rgba(255, 255, 255, 0.06);
        --text-primary: #e2e2e8;
        --text-secondary: #8888a0;
        --text-tertiary: #55556a;
        --text-accent: #a78bfa;
        --accent-glow: rgba(167, 139, 250, .12);
        --max-width: 1280px;
        --transition-fast: .15s ease;
      }

      /* ── Header ── */
      .docs-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10, 10, 15, .85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-primary);
        height: 56px;
      }
      .docs-header__inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 100%;
        display: flex;
        align-items: center;
      }
      .docs-header__brand {
        display: flex;
        align-items: center;
        gap: .75rem;
      }
      .docs-header__logo-link {
        display: flex;
        align-items: center;
        text-decoration: none;
      }
      .docs-header__breadcrumb-link {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color var(--transition-fast);
      }
      .docs-header__breadcrumb-link:hover {
        color: var(--text-accent);
      }
      .docs-header__breadcrumb-sep {
        color: var(--text-tertiary);
        margin: 0 2px;
        font-weight: 400;
      }
      .docs-header__icon { border-radius: 6px; }
      .docs-header__title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: -.01em;
      }

      /* ── Layout ── */
      .docs-layout {
        display: flex;
        max-width: var(--max-width);
        margin: 0 auto;
        position: relative;
      }

      /* ── Sidebar ── */
      .docs-sidebar {
        position: sticky;
        top: 56px;
        height: calc(100vh - 56px);
        width: 180px;
        flex-shrink: 0;
        padding: 24px 0 24px 24px;
        overflow-y: auto;
        display: none;
      }
      @media (min-width: 1024px) {
        .docs-sidebar { display: block; }
      }
      .docs-sidebar__list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .docs-sidebar__link {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        padding: 8px 14px;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-tertiary);
        text-decoration: none;
        border-radius: 8px;
        border: none;
        background: none;
        cursor: pointer;
        transition: color var(--transition-fast), background var(--transition-fast);
        text-align: left;
        font-family: inherit;
        line-height: 1.4;
      }
      .docs-sidebar__link:hover {
        color: var(--text-secondary);
        background: rgba(255, 255, 255, 0.04);
      }
      .docs-sidebar__link--active {
        color: var(--text-accent);
        background: rgba(167, 139, 250, 0.08);
        font-weight: 600;
      }
      .docs-sidebar__link svg {
        flex-shrink: 0;
        opacity: 0.7;
      }
      .docs-sidebar__link--active svg {
        opacity: 1;
      }
      .docs-sidebar__divider {
        height: 1px;
        background: var(--border-color);
        margin: 16px 14px 12px 14px;
      }
      .docs-sidebar__label {
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0 14px 4px;
      }

      /* ── Main ── */
      .docs-main {
        flex: 1;
        min-width: 0;
        max-width: 860px;
        padding: 32px 24px 64px;
      }

      /* ── Hero ── */
      .docs-hero {
        margin-bottom: 2.5rem;
      }
      .docs-hero__heading {
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -.02em;
        margin-bottom: .5rem;
      }
      .docs-hero__sub {
        color: var(--text-secondary);
        font-size: 1.05rem;
        line-height: 1.6;
      }

      /* ── Quick Start ── */
      .quickstart {
        margin-bottom: 3rem;
        padding: 1.75rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-primary);
        border-radius: 12px;
        scroll-margin-top: 72px;
      }
      .quickstart__heading {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-accent);
        margin-bottom: 1.25rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        font-size: .8rem;
      }
      .quickstart__steps {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .quickstart__step {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }
      .quickstart__num {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-glow);
        color: var(--text-accent);
        border: 1px solid rgba(167, 139, 250, .25);
        border-radius: 50%;
        font-size: .8rem;
        font-weight: 700;
      }
      .quickstart__label {
        font-weight: 600;
        font-size: .95rem;
        margin-bottom: .15rem;
      }
      .quickstart__code {
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        font-size: .85rem;
        color: var(--text-accent);
        background: var(--bg-tertiary);
        padding: .2rem .5rem;
        border-radius: 5px;
        border: 1px solid var(--border-secondary);
      }
      .quickstart__desc {
        color: var(--text-secondary);
        font-size: .9rem;
        line-height: 1.5;
      }

      /* ── IDE Tabs ── */
      .quickstart__tabs {
        display: flex;
        gap: 0;
        margin-bottom: .75rem;
        border-bottom: 1px solid var(--border-secondary);
      }
      .quickstart__tab {
        padding: .4rem .75rem;
        font-size: .8rem;
        font-weight: 500;
        color: var(--text-tertiary);
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: color var(--transition-fast), border-color var(--transition-fast);
        font-family: inherit;
      }
      .quickstart__tab:hover {
        color: var(--text-secondary);
      }
      .quickstart__tab--active {
        color: var(--text-accent);
        border-bottom-color: var(--text-accent);
      }
      .quickstart__panel { display: none; }
      .quickstart__panel--active { display: block; }

      /* ── IDE Switcher (single bar between step 2 and 3) ── */
      .quickstart__ide-switcher {
        margin: 1.25rem 0;
        padding-left: calc(28px + 1rem); /* align with step content (num width + gap) */
      }

      /* ── Quick Start – hints ── */
      .quickstart__hint {
        font-size: .8rem;
        color: var(--text-tertiary);
        font-style: italic;
        margin-top: .5rem;
      }

      /* ── Quick Start – options (A/B) ── */
      .quickstart__options {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin-top: .75rem;
      }
      .quickstart__option {
        display: flex;
        gap: .75rem;
        padding: 1rem 1.25rem;
        background: var(--bg-tertiary);
        border: 1px solid var(--border-secondary);
        border-radius: 10px;
      }
      .quickstart__option-letter {
        flex-shrink: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-glow);
        color: var(--text-accent);
        border: 1px solid rgba(167, 139, 250, .2);
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 700;
        margin-top: 2px;
      }
      .quickstart__option-title {
        font-weight: 600;
        font-size: .9rem;
        margin-bottom: .35rem;
        display: flex;
        align-items: center;
        gap: .5rem;
      }
      .quickstart__option-badge {
        font-size: .65rem;
        font-weight: 600;
        color: var(--text-accent);
        background: var(--accent-glow);
        border: 1px solid rgba(167, 139, 250, .2);
        padding: .1rem .4rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: .04em;
      }

      /* ── Quick Start – substeps ── */
      .quickstart__substeps {
        display: flex;
        flex-direction: column;
        gap: .5rem;
        margin-top: .5rem;
      }
      .quickstart__substep {
        display: flex;
        gap: .6rem;
        align-items: flex-start;
      }
      .quickstart__substep-num {
        flex-shrink: 0;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-tertiary);
        border: 1px solid var(--border-secondary);
        border-radius: 50%;
        font-size: .7rem;
        font-weight: 600;
        margin-top: 2px;
      }

      /* ── Demo Video ── */
      .demo-video-section {
        margin-bottom: 3rem;
        scroll-margin-top: 72px;
      }
      .demo-video-section__heading {
        font-size: .8rem;
        font-weight: 600;
        color: var(--text-accent);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 1rem;
      }
      .demo-video-section__wrapper {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-primary);
        background: #000;
      }
      .demo-video-section__player {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 12px;
      }

      /* ── Doc cards grid ── */
      .docs-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 3rem;
      }
      .doc-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.5rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-primary);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: border-color .2s, background .2s, transform .15s;
      }
      .doc-card:hover {
        border-color: var(--text-accent);
        background: var(--bg-tertiary);
        transform: translateY(-1px);
      }
      .doc-card__icon {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-glow);
        border: 1px solid rgba(167, 139, 250, .2);
        border-radius: 10px;
        color: var(--text-accent);
      }
      .doc-card__body {
        flex: 1;
        min-width: 0;
      }
      .doc-card__header {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: .35rem;
      }
      .doc-card__title {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -.01em;
      }
      .doc-card__badge {
        font-size: .7rem;
        font-weight: 600;
        color: var(--text-accent);
        background: var(--accent-glow);
        border: 1px solid rgba(167, 139, 250, .2);
        padding: .15rem .5rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: .04em;
        white-space: nowrap;
      }
      .doc-card__desc {
        color: var(--text-secondary);
        font-size: .9rem;
        line-height: 1.5;
      }
      .doc-card__arrow {
        flex-shrink: 0;
        color: var(--text-secondary);
        transition: color .2s, transform .2s;
      }
      .doc-card:hover .doc-card__arrow {
        color: var(--text-accent);
        transform: translateX(3px);
      }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .docs-hero__heading { font-size: 1.4rem; }
        .doc-card { padding: 1.25rem; gap: 1rem; }
        .doc-card__icon { width: 40px; height: 40px; }
        .doc-card__arrow { display: none; }
        .quickstart { padding: 1.25rem; }
      }
    </style>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const tablist = document.querySelector('.quickstart__ide-switcher .quickstart__tabs');
        if (!tablist) return;

        const allPanels = document.querySelectorAll<HTMLElement>('.quickstart__panel[data-ide]');
        const allTabs = tablist.querySelectorAll<HTMLElement>('.quickstart__tab[data-ide]');

        function switchIde(ide: string) {
          allTabs.forEach(t => {
            const isMatch = t.dataset.ide === ide;
            t.classList.toggle('quickstart__tab--active', isMatch);
            t.setAttribute('aria-selected', String(isMatch));
          });
          allPanels.forEach(p => {
            const isMatch = p.dataset.ide === ide;
            p.classList.toggle('quickstart__panel--active', isMatch);
            p.hidden = !isMatch;
          });
        }

        tablist.addEventListener('click', (e) => {
          const target = e.target as HTMLElement | null;
          const tab = target?.closest<HTMLElement>('.quickstart__tab');
          if (!tab || !tab.dataset.ide) return;
          switchIde(tab.dataset.ide);
        });
      });
    </script>
  </body>
</html>
