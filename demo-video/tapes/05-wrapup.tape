# Scene 5: Wrap up
Output clips/05-wrapup.mp4
Set FontSize 16
Set Width 1280
Set Height 720
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set Padding 16
Set Framerate 30
Set Shell "bash"
Set WindowBar Colorful

Hide
Type "cd /tmp/opencastle-demo && export PS1='$ ' && clear"
Enter
Sleep 500ms
Show

Sleep 500ms
Type "npx opencastle init"
Sleep 2s

# Hold — let the audio finish
Sleep 11280ms
